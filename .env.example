# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). Free tier, no credit card required:
# https://supabase.com/dashboard

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Only needed locally to run `npm run seed`. Get it from Project Settings ->
# API -> service_role (the "secret" key). NEVER commit this or expose it to
# the browser -- it bypasses Row Level Security entirely.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
